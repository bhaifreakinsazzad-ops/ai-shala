# ============================================
# YUSRA SYNTHETIC INTELLIGENCE - Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change-this-to-a-long-random-secret-string-min-32-chars

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
# Set automatically by Render; used by server.js's CORS allowlist
RENDER_EXTERNAL_URL=

# ============================================
# SUPABASE (Free at supabase.com)
# 1. Go to https://supabase.com
# 2. Create a new project
# 3. Go to Settings > API
# 4. Copy the URL and service_role key
# ============================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ============================================
# FREE AI API KEYS
# ============================================

# GROQ (Free at https://console.groq.com)
# Models: LLaMA 3.3 70B, Gemma 2, Mixtral
GROQ_API_KEY=gsk_your_groq_api_key_here

# GOOGLE GEMINI (Free at https://aistudio.google.com/app/apikey)
# Models: Gemini 2.0 Flash, 1.5 Flash, 1.5 Pro
GEMINI_API_KEY=AIza_your_gemini_api_key_here

# OPENROUTER (Free tier at https://openrouter.ai)
# Free models: Mistral 7B, LLaMA 3.2, DeepSeek, Phi-3
OPENROUTER_API_KEY=sk-or-your_openrouter_api_key_here

# TOGETHER AI (Free tier at https://api.together.xyz)
# Free models: LLaMA 3, Mistral, Qwen
TOGETHER_API_KEY=your_together_api_key_here

# COHERE (Free tier at https://cohere.com)
# Models: Command R, Command R+
COHERE_API_KEY=your_cohere_api_key_here

# OPENAI (paid)
OPENAI_API_KEY=sk-your_openai_api_key_here

# ANTHROPIC (paid)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# CEREBRAS (Free tier at https://cloud.cerebras.ai — 5 req/min, 1M tokens/day)
# Models: gpt-oss-120b, zai-glm-4.7
CEREBRAS_API_KEY=csk-your_cerebras_api_key_here

# HUGGING FACE (Free $0.10/month credit at https://huggingface.co/settings/tokens)
# Routes through Inference Providers — pick cheap models to stay within the free credit
HUGGINGFACE_API_KEY=hf_your_huggingface_api_key_here

# LLM7 (Free community-run proxy at https://token.llm7.io — not an official vendor endpoint)
LLM7_API_KEY=your_llm7_api_key_here

# CLOUDFLARE WORKERS AI (Free within daily Neuron allowance)
# Needs BOTH values — API token from https://dash.cloudflare.com/profile/api-tokens (Workers AI template)
# and your Account ID from the Cloudflare dashboard's Workers AI page ("Use REST API" panel)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# ============================================
# WEB SEARCH (Free tier at https://tavily.com — 1,000 searches/month)
# Powers the Internet Search and Research & Thinking features
# ============================================
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# ============================================
# ADMIN SETTINGS
# ============================================
# Phone number for payment confirmation
PAYMENT_PHONE=01778307704
# Comma-separated list of admin user emails
ADMIN_EMAILS=admin@yusra.ai

# ============================================
# APP SETTINGS
# ============================================
APP_NAME=Yusra Synthetic Intelligence
APP_URL=https://yusra.ai
ALLOWED_ORIGINS=http://localhost:5173
FREE_TRIAL_DAYS=7
FREE_DAILY_LIMIT=50
FREE_IMAGE_DAILY_LIMIT=5
